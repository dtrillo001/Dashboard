def as_row(category, ticker, price, prev_close, shares, p_ytd, p_1y, p_5y):
    price_diff = (price - prev_close) if (price is not None and prev_close is not None) else np.nan
    total = (price * shares) if (price is not None and shares is not None) else 0.0
    day_perf = (price / prev_close - 1.0) if (price and prev_close and prev_close != 0) else np.nan
    return dict(
        Category=category,
        **{"Ticker/Account": ticker},
        **{"Current Price": price},
        **{"Prev Close": prev_close},
        **{"Price Diff ($)": price_diff},
        Shares=shares,
        **{"Total Value (Price × Shares)": total},
        **{"1-Day Perf (%)": day_perf},
        **{"YTD Perf (%)": p_ytd},
        **{"1-Year Perf (%)": p_1y},
        **{"5-Year Perf (%)": p_5y},
    )

