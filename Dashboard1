def fmt_money(v):
    return "" if pd.isna(v) else f"${float(v):,.2f}"

def fmt_shares(v):
    return "" if pd.isna(v) else f"{float(v):,.4f}".rstrip("0").rstrip(".")

def fmt_pct(v):
    if pd.isna(v): return "N/A"
    return f"{float(v)*100:,.2f}%"

