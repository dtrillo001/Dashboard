def fetch_history(tickers):
    if not tickers:
        return pd.DataFrame()
    hist = yf.download(tickers, period="5y", interval="1d", auto_adjust=True, progress=False, threads=True)
    if isinstance(hist.columns, pd.MultiIndex):
        close = hist["Close"]
    else:
        close = hist[["Close"]]
        close.columns = [tickers[0]]
    return close.dropna(how="all")

def anchored_return(series, anchor_date):
    try:
        if series.index.tz is None:
            series = series.tz_localize("UTC")
        idx = series.index[series.index.get_loc(anchor_date, method="pad")] if series.index.min() <= anchor_date else series.index.min()
        base = float(series.loc[idx])
        last = float(series.iloc[-1])
        return (last / base - 1.0) if base else np.nan
    except Exception:
        return np.nan

def weighted_avg(values, weights):
    v = pd.Series(values, dtype="float64")
    w = pd.Series(weights, dtype="float64")
    m = (~v.isna()) & (w > 0)
    if not m.any():
        return np.nan
    return float((v[m] * w[m]).sum() / w[m].sum())

